
@model GraphOrgViewer.Models.RoomCalendarPageViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Sale";

    var previousDay = Model.SelectedDate.AddDays(-1).ToString("yyyy-MM-dd");
    var nextDay = Model.SelectedDate.AddDays(1).ToString("yyyy-MM-dd");

    var selectedRoom = Model.Rooms.FirstOrDefault(x => x.Email == Model.SelectedRoomEmail);

    var slots = new List<DateTime>();
    var startDay = Model.SelectedDate.Date.AddHours(7);
    var endDay = Model.SelectedDate.Date.AddHours(18);

    for (var time = startDay; time < endDay; time = time.AddMinutes(30))
    {
        slots.Add(time);
    }

    bool IsBusy(DateTime slotStart)
    {
        var slotEnd = slotStart.AddMinutes(30);

        return Model.Events.Any(e =>
            e.Start < slotEnd &&
            e.End > slotStart);
    }

    var organizerUsers = Model.Users ?? new List<GraphOrgViewer.Models.GraphUserViewModel>();
}
@if (string.IsNullOrWhiteSpace(Model.SelectedRoomEmail))
{
    <div class="room-select-screen">
        <div class="room-select-card">
            <h1>Wybierz salę</h1>
            <p>Wskaż salę, dla której chcesz uruchomić kiosk rezerwacji.</p>

            <div class="room-select-grid">
                @foreach (var room in Model.Rooms)
                {
                    <a class="room-select-tile"
                    asp-controller="Rooms"
                    asp-action="Index"
                    asp-route-roomEmail="@room.Email"
                    asp-route-date="@Model.SelectedDate.ToString("yyyy-MM-dd")">
                        <span>@room.Name</span>
                        <small>@room.Email</small>
                    </a>
                }
            </div>
        </div>
    </div>

    <style>
        header,
        .navbar,
        footer {
            display: none !important;
        }

        body {
            background: #f4f6f9;
            overflow: hidden;
        }

        .container {
            max-width: none !important;
            width: 100% !important;
            padding: 0 !important;
        }

        .room-select-screen {
            width: 100vw;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px;
        }

        .room-select-card {
            width: min(1100px, 100%);
            background: white;
            border-radius: 28px;
            padding: 36px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
        }

        .room-select-card h1 {
            font-size: 42px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .room-select-card p {
            color: #6b7280;
            font-size: 20px;
            margin-bottom: 28px;
        }

        .room-select-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 18px;
        }

        .room-select-tile {
            min-height: 130px;
            padding: 24px;
            border-radius: 22px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            text-decoration: none;
            color: #111827;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
            transition: 0.15s ease;
        }

        .room-select-tile:hover {
            transform: translateY(-3px);
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            color: white;
        }

        .room-select-tile span {
            display: block;
            font-size: 26px;
            font-weight: 800;
        }

        .room-select-tile small {
            display: block;
            margin-top: 10px;
            font-size: 15px;
            opacity: 0.8;
        }
    </style>

    return;
}
<div class="rooms-wrapper">
    <div class="rooms-header">
        <div>
            <h2 class="rooms-title">@(selectedRoom?.Name ?? "Sala")</h2>
        </div>

        <div class="day-nav">
            <a class="day-btn"
               asp-controller="Rooms"
               asp-action="Index"
               asp-route-roomEmail="@Model.SelectedRoomEmail"
               asp-route-date="@previousDay">
                ‹
            </a>

            <div class="day-current">
                @Model.SelectedDate.ToString("dd.MM.yyyy")
            </div>

            <a class="day-btn"
               asp-controller="Rooms"
               asp-action="Index"
               asp-route-roomEmail="@Model.SelectedRoomEmail"
               asp-route-date="@nextDay">
                ›
            </a>
        </div>
    </div>

    <div class="rooms-layout">
        <div class="calendar-card">
            <div class="calendar-grid">
                @foreach (var slot in slots)
                {
                    var busy = IsBusy(slot);
                    var relatedEvent = Model.Events.FirstOrDefault(e =>
                        e.Start < slot.AddMinutes(30) &&
                        e.End > slot);

                    <button type="button"
                            class="time-slot @(busy ? "busy" : "free")"
                            data-time="@slot.ToString("yyyy-MM-ddTHH:mm:ss")"
                            disabled="@(busy ? "disabled" : null)">
                        <span class="slot-time">@slot.ToString("HH:mm")</span>

                        @if (busy && relatedEvent != null)
                        {
                            <span class="slot-title">@relatedEvent.Subject</span>
                        }
                        else
                        {
                            <span class="slot-title">Wolne</span>
                        }
                    </button>
                }
            </div>
        </div>

        <div class="booking-panel">
            <h3>Rezerwacja</h3>

            <form method="post" asp-controller="Rooms" asp-action="Book" id="bookingForm">
                <input type="hidden" name="roomEmail" value="@Model.SelectedRoomEmail" />
                <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="start" id="bookingStart" />
                <input type="hidden" name="end" id="bookingEnd" />
                <input type="hidden" name="organizerEmail" id="organizerEmail" />

                <div class="booking-summary">
                    <div class="summary-label">Wybrany termin</div>
                    <div id="selectedRange" class="summary-value">
                        Nie wybrano
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Organizator</label>
                    <input type="text"
                           id="organizerSearch"
                           class="form-control"
                           placeholder="Wpisz pierwsze litery..." />

                    <div id="organizerSuggestions" class="suggestions"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nazwa spotkania</label>
                    <input type="text"
                           name="subject"
                           class="form-control"
                           placeholder="Np. Spotkanie projektowe"
                           />
                </div>

                <button type="submit" class="book-btn" id="bookBtn" disabled>
                    Rezerwuj
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    body {
        background: #f4f6f9;
    }

    .rooms-wrapper {
        max-width: 1300px;
        margin: 30px auto;
        padding: 24px;
    }

    .rooms-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        gap: 20px;
    }

    .rooms-title {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
    }

    .rooms-subtitle {
        margin-top: 6px;
        color: #6b7280;
        font-size: 15px;
    }

    .day-nav {
        display: flex;
        align-items: center;
        gap: 12px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 8px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
    }

    .day-btn {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #111827;
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        line-height: 1;
        font-weight: 700;
    }

    .day-btn:hover {
        background: #2563eb;
        color: white;
    }

    .day-current {
        min-width: 130px;
        text-align: center;
        font-weight: 700;
        color: #111827;
    }

    .rooms-filter {
        display: grid;
        grid-template-columns: 1fr 220px 140px;
        gap: 16px;
        align-items: end;
        background: white;
        padding: 18px;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
        margin-bottom: 22px;
    }

    .filter-btn,
    .book-btn {
        border: 0;
        border-radius: 12px;
        background: #111827;
        color: white;
        font-weight: 700;
        padding: 11px 16px;
        transition: 0.15s ease;
    }

    .filter-btn:hover,
    .book-btn:hover {
        background: #2563eb;
    }

    .book-btn:disabled {
        background: #9ca3af;
        cursor: not-allowed;
    }

    .rooms-layout {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 22px;
        align-items: start;
    }

    .calendar-card,
    .booking-panel {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
        padding: 18px;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
    }

    .time-slot {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        min-height: 82px;
        padding: 12px;
        text-align: left;
        background: #ffffff;
        transition: 0.15s ease;
        cursor: pointer;
    }

    .time-slot.free:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.12);
        border-color: #2563eb;
    }

    .time-slot.selected {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        border-color: transparent;
        box-shadow: 0 12px 26px rgba(37, 99, 235, 0.25);
    }

    .time-slot.busy {
        background: #f3f4f6;
        border-color: #d1d5db;
        color: #6b7280;
        cursor: not-allowed;
        opacity: 0.8;
    }

    .slot-time {
        display: block;
        font-weight: 800;
        font-size: 16px;
    }

    .slot-title {
        display: block;
        margin-top: 8px;
        font-size: 13px;
        word-break: break-word;
    }

    .booking-panel h3 {
        font-size: 22px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 18px;
    }

    .booking-summary {
        padding: 14px;
        border-radius: 14px;
        background: #eef2ff;
        color: #3730a3;
        margin-bottom: 18px;
    }

    .summary-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.8;
    }

    .summary-value {
        margin-top: 4px;
        font-size: 18px;
        font-weight: 800;
    }

    .suggestions {
        margin-top: 6px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        display: none;
        background: white;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
    }

    .suggestion-item {
        padding: 10px 12px;
        cursor: pointer;
        border-bottom: 1px solid #f3f4f6;
    }

    .suggestion-item:hover {
        background: #eef2ff;
    }

    .suggestion-name {
        font-weight: 700;
        color: #111827;
    }

    .suggestion-mail {
        font-size: 12px;
        color: #6b7280;
    }

    @@media (max-width: 992px) {
        .rooms-layout {
            grid-template-columns: 1fr;
        }

        .calendar-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .rooms-filter {
            grid-template-columns: 1fr;
        }

        .rooms-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<style>
    /* KIOSK / TABLET MODE */
