</style>

    @{
        var usersJson = JsonSerializer.Serialize(
            organizerUsers
                .Select(u => new
                {
                    name = u.DisplayName ?? "",
                    mail = u.Mail ?? u.UserPrincipalName ?? ""
                })
                .Where(u => !string.IsNullOrWhiteSpace(u.name) && !string.IsNullOrWhiteSpace(u.mail))
                .ToList()
        );
    }

<script>
    const users = @Html.Raw(usersJson);

    let selectedSlots = [];

    const slots = document.querySelectorAll(".time-slot.free");
    const selectedRange = document.getElementById("selectedRange");
    const bookingStart = document.getElementById("bookingStart");
    const bookingEnd = document.getElementById("bookingEnd");
    const bookBtn = document.getElementById("bookBtn");
    const organizerEmail = document.getElementById("organizerEmail");

    slots.forEach(slot => {
        slot.addEventListener("click", () => {
            const time = slot.dataset.time;

            if (selectedSlots.includes(time)) {
                selectedSlots = selectedSlots.filter(x => x !== time);
                slot.classList.remove("selected");
            } else {
                selectedSlots.push(time);
                slot.classList.add("selected");
            }

            selectedSlots.sort();
            updateSelectedRange();
        });
    });

    function updateSelectedRange() {
        if (selectedSlots.length === 0) {
            selectedRange.textContent = "Nie wybrano";
            bookingStart.value = "";
            bookingEnd.value = "";
            refreshBookButton();
            return;
        }

        const start = new Date(selectedSlots[0]);
        const end = new Date(selectedSlots[selectedSlots.length - 1]);
        end.setMinutes(end.getMinutes() + 30);

        selectedRange.textContent =
            formatTime(start) + " - " + formatTime(end);

        bookingStart.value = toLocalInputValue(start);
        bookingEnd.value = toLocalInputValue(end);

        refreshBookButton();
    }

    function formatTime(date) {
        return date.toLocaleTimeString("pl-PL", {
            hour: "2-digit",
            minute: "2-digit"
        });
    }

    function toLocalInputValue(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        const hour = String(date.getHours()).padStart(2, "0");
        const minute = String(date.getMinutes()).padStart(2, "0");

        return `${year}-${month}-${day}T${hour}:${minute}:00`;
    }

    const organizerSearch = document.getElementById("organizerSearch");
    const suggestions = document.getElementById("organizerSuggestions");

    organizerSearch.addEventListener("input", () => {
        const value = organizerSearch.value.trim().toLowerCase();

        organizerEmail.value = "";
        refreshBookButton();

        if (value.length < 2) {
            suggestions.style.display = "none";
            suggestions.innerHTML = "";
            return;
        }

        const matched = users
            .filter(u =>
                u.name.toLowerCase().includes(value) ||
                u.mail.toLowerCase().includes(value))
            .slice(0, 8);

        if (matched.length === 0) {
            suggestions.style.display = "none";
            suggestions.innerHTML = "";
            return;
        }

        suggestions.innerHTML = matched.map(u => `
            <div class="suggestion-item" data-name="${u.name}" data-mail="${u.mail}">
                <div class="suggestion-name">${u.name}</div>
                <div class="suggestion-mail">${u.mail}</div>
            </div>
        `).join("");

        suggestions.style.display = "block";

        document.querySelectorAll(".suggestion-item").forEach(item => {
            item.addEventListener("click", () => {
                organizerSearch.value = item.dataset.name;
                organizerEmail.value = item.dataset.mail;
                suggestions.style.display = "none";
                refreshBookButton();
            });
        });
    });

    function refreshBookButton() {
        bookBtn.disabled =
            !bookingStart.value ||
            !bookingEnd.value ||
            !organizerEmail.value;
    }
</script>