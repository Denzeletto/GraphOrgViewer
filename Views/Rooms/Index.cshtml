.navbar,
footer {
    display: none !important;
}

.container {
    max-width: none !important;
    width: 100% !important;
    padding: 0 !important;
}

main {
    padding: 0 !important;
}

body {
    overflow: hidden;
    background: #f4f6f9;
}

.rooms-wrapper {
    max-width: none;
    height: 100vh;
    margin: 0;
    padding: 18px;
    display: flex;
    flex-direction: column;
}

.rooms-header {
    margin-bottom: 14px;
}

.rooms-title {
    font-size: 28px;
}

.rooms-subtitle {
    font-size: 14px;
}

.rooms-filter {
    display: none;
}

.day-nav {
