
@model GraphOrgViewer.Models.RoomCalendarPageViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Sale";

    var selectedRoom = Model.Rooms.FirstOrDefault(x => x.Email == Model.SelectedRoomEmail);

    var slots = new List<DateTime>();
    var startDay = Model.SelectedDate.Date.AddHours(7);
    var endDay = Model.SelectedDate.Date.AddHours(17).AddMinutes(30);

    for (var time = startDay; time < endDay; time = time.AddMinutes(30))
    {
        slots.Add(time);
    }

    bool IsBusy(DateTime slotStart)
    {
        var slotEnd = slotStart.AddMinutes(30);

        return Model.Events.Any(e =>
            e.Start < slotEnd &&
            e.End > slotStart);
    }

    var organizerUsers = Model.Users ?? new List<GraphOrgViewer.Models.GraphUserViewModel>();
}
@if (string.IsNullOrWhiteSpace(Model.SelectedRoomEmail))
{
    <div class="room-select-screen">
        <div class="room-select-card">
            <h1>Wybierz salę</h1>
            <p>Wskaż salę, dla której chcesz uruchomić kiosk rezerwacji.</p>

            <div class="room-select-grid">
                @foreach (var room in Model.Rooms)
                {
                    <a class="room-select-tile"
                    asp-controller="Rooms"
                    asp-action="Index"
                    asp-route-roomEmail="@room.Email">
                        <span>@room.Name</span>
                        <small>@room.Email</small>
                    </a>
                }
            </div>
        </div>
    </div>

    <style>
        header,
        .navbar,
        footer {
            display: none !important;
        }

        body {
            background: #f4f6f9;
            overflow: hidden;
        }

        .container {
            max-width: none !important;
            width: 100% !important;
            padding: 0 !important;
        }

        .room-select-screen {
            width: 100vw;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px;
        }

        .room-select-card {
            width: min(1100px, 100%);
            background: white;
            border-radius: 28px;
            padding: 36px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
        }

        .room-select-card h1 {
            font-size: 42px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .room-select-card p {
            color: #6b7280;
            font-size: 20px;
            margin-bottom: 28px;
        }

        .room-select-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 18px;
        }

        .room-select-tile {
            min-height: 130px;
            padding: 24px;
            border-radius: 22px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            text-decoration: none;
            color: #111827;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
            transition: 0.15s ease;
        }

        .room-select-tile:hover {
            transform: translateY(-3px);
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            color: white;
        }

        .room-select-tile span {
            display: block;
            font-size: 26px;
            font-weight: 800;
        }

        .room-select-tile small {
            display: block;
            margin-top: 10px;
            font-size: 15px;
            opacity: 0.8;
        }
    </style>

    return;
}
<div class="rooms-wrapper">
    @if (TempData["RoomBookingSuccess"] != null)
    {
        <div class="booking-toast booking-toast-success">
            @TempData["RoomBookingSuccess"]
        </div>
    }

    @if (TempData["RoomBookingError"] != null)
    {
        <div class="booking-toast booking-toast-error">
            @TempData["RoomBookingError"]
        </div>
    }

    <div class="rooms-header">
        <div>
            <h2 class="rooms-title">@(selectedRoom?.Name ?? "Sala")</h2>
        </div>

        <div class="top-right-panel">
            <div class="current-time-box">
                <span id="currentTime">--:--</span>
            </div>

            <div class="day-nav">
                <div class="day-current">
                    <span id="currentDate">
                        @DateTime.Today.ToString("dd.MM.yyyy")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="rooms-layout">
        <div class="calendar-card">
            <div class="calendar-grid">
                @foreach (var slot in slots)
                {
                    var busy = IsBusy(slot);
                    var past = Model.SelectedDate.Date == DateTime.Today && slot < DateTime.Now;                   
                    var relatedEvent = Model.Events.FirstOrDefault(e =>
                        e.Start < slot.AddMinutes(30) &&
                        e.End > slot);

                    <button type="button"
                            class="time-slot @(busy ? "busy" : past ? "past" : "free")"
                            data-time="@slot.ToString("yyyy-MM-ddTHH:mm:ss")"
                            disabled="@((busy || past) ? "disabled" : null)">
                        <span class="slot-time">@slot.ToString("HH:mm")</span>

                        @if (busy && relatedEvent != null)
                        {
                            <span class="slot-title">@relatedEvent.Subject</span>
                        }
                        else
                        {
                            <span class="slot-title">Wolne</span>
                        }
                    </button>
                }
            </div>
        </div>

        <div class="booking-panel">
            <h3>Rezerwacja</h3>

            <form method="post" asp-controller="Rooms" asp-action="Book" id="bookingForm">
                <input type="hidden" name="roomEmail" value="@Model.SelectedRoomEmail" />
                <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="start" id="bookingStart" />
                <input type="hidden" name="end" id="bookingEnd" />
                <input type="hidden" name="organizerEmail" id="organizerEmail" />

                <div class="booking-summary">
                    <div class="summary-label">Wybrany termin</div>
                    <div id="selectedRange" class="summary-value">
                        Nie wybrano
                    </div>
                </div>
                <button type="button" class="clear-btn" id="clearSelectionBtn">
                    Wyczyść
                </button>
                <div class="mb-3">
                    <label class="form-label">Organizator</label>
                    <input type="text"
                           id="organizerSearch"
                           class="form-control"
                           placeholder="Wpisz pierwsze litery..." />

                    <div id="organizerSuggestions" class="suggestions"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nazwa spotkania</label>
                    <input type="text"
                           name="subject"
                           class="form-control"
                           placeholder="Np. Spotkanie projektowe"
                           />
                </div>

                <button type="submit" class="book-btn" id="bookBtn" disabled>
                    Rezerwuj
                </button>
            </form>
        </div>
    </div>
</div>
<style>
    :root {
        --side-panel-width: 340px;
    }

    header,
    .navbar,
    footer {
        display: none !important;
    }

    .container {
        max-width: none !important;
        width: 100% !important;
        padding: 0 !important;
    }

    main {
        padding: 0 !important;
    }

    body {
        overflow: hidden;
        background: #f4f6f9;
    }

    .rooms-wrapper {
        max-width: none;
        height: 100vh;
        margin: 0;
        padding: 18px;
        display: flex;
        flex-direction: column;
    }

    .rooms-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 14px;
    }

    .rooms-title {
        font-size: 28px;
        font-weight: 800;
        color: #1f2937;
        margin: 0;
    }

    .top-right-panel {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .current-time-box {
        width: 120px;
        height: 66px;
        border-radius: 16px;
        background: #111827;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 21px;
        font-weight: 900;
        letter-spacing: 1px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
    }

    .day-nav {
        width: var(--side-panel-width);
        height: 66px;
        display: grid;
        grid-template-columns: 1fr;
        align-items: center;
        gap: 8px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 6px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
    }

    .day-btn {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        background: #111827;
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 38px;
        line-height: 1;
        font-weight: 800;
    }

    .day-btn:hover {
        background: #2563eb;
        color: white;
    }

    .day-current {
        text-align: center;
        font-size: 18px;
        font-weight: 900;
        color: #111827;
        white-space: nowrap;
    }

    .rooms-layout {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: 1fr var(--side-panel-width);
        gap: 16px;
    }

    .calendar-card,
    .booking-panel {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
        padding: 14px;
    }

    .calendar-card {
        min-height: 0;
        overflow-y: auto;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .time-slot {
        min-height: 86px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 12px;
        text-align: left;
        background: #ffffff;
        transition: 0.15s ease;
        cursor: pointer;
    }

    .time-slot.free:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.12);
        border-color: #2563eb;
    }

    .time-slot.selected {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        border-color: transparent;
        box-shadow: 0 12px 26px rgba(37, 99, 235, 0.25);
    }

    .time-slot.busy {
        background: #f3f4f6;
        border-color: #d1d5db;
        color: #6b7280;
        cursor: not-allowed;
        opacity: 0.8;
    }

    .time-slot.range-blocked {
        background: #e5e7eb !important;
        color: #9ca3af !important;
        border-color: #d1d5db !important;
        cursor: not-allowed;
        opacity: 0.75;
    }

    .slot-time {
        display: block;
        font-weight: 900;
        font-size: 20px;
    }

    .slot-title {
        display: block;
        margin-top: 8px;
        font-size: 13px;
        word-break: break-word;
    }

    .booking-panel {
        height: 100%;
        overflow-y: auto;
    }

    .booking-panel h3 {
        font-size: 24px;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 18px;
    }

    .booking-summary {
        padding: 14px;
        border-radius: 14px;
        background: #eef2ff;
        color: #3730a3;
        margin-bottom: 12px;
    }

    .summary-label {
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        opacity: 0.8;
    }

    .summary-value {
        margin-top: 4px;
        font-size: 22px;
        font-weight: 900;
    }

    .clear-btn {
        width: 100%;
        min-height: 48px;
        margin-bottom: 18px;
        border: 0;
        border-radius: 14px;
        background: #e5e7eb;
        color: #111827;
        font-weight: 800;
        font-size: 16px;
        transition: 0.15s ease;
    }

    .clear-btn:hover {
        background: #d1d5db;
    }

    .clear-btn:active {
        transform: scale(0.98);
    }

    .form-control,
    .form-select {
        min-height: 48px;
        font-size: 16px;
        border-radius: 12px;
    }

    .form-label {
        font-weight: 700;
        color: #374151;
    }

    .book-btn {
        width: 100%;
        min-height: 56px;
        border: 0;
        border-radius: 16px;
        background: #111827;
        color: white;
        font-weight: 800;
        font-size: 18px;
        transition: 0.15s ease;
    }

    .book-btn:hover {
        background: #2563eb;
    }

    .book-btn:disabled {
        background: #9ca3af;
        cursor: not-allowed;
    }

    .suggestions {
        margin-top: 6px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        display: none;
        background: white;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
    }

    .suggestion-item {
        padding: 14px;
        cursor: pointer;
        border-bottom: 1px solid #f3f4f6;
    }

    .suggestion-item:hover {
        background: #eef2ff;
    }

    .suggestion-name {
        font-size: 16px;
        font-weight: 800;
        color: #111827;
    }

    .suggestion-mail {
        font-size: 13px;
        color: #6b7280;
    }

    .booking-toast {
        position: fixed;
        top: 18px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        padding: 16px 24px;
        border-radius: 16px;
        font-size: 18px;
        font-weight: 800;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.18);
    }

    .booking-toast-success {
        background: #dcfce7;
        color: #166534;
    }

    .booking-toast-error {
        background: #fee2e2;
        color: #991b1b;
    }

    .time-slot.past {
        background: #f1f5f9;
        border-color: #e2e8f0;
        color: #94a3b8;
        cursor: not-allowed;
        opacity: 0.65;
    }

    @@media (orientation: portrait) {
        .rooms-layout {
            grid-template-columns: 1fr;
            grid-template-rows: 1fr auto;
        }

        .booking-panel {
            height: auto;
            max-height: 38vh;
        }

        .calendar-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 900px) {
        :root {
            --side-panel-width: 300px;
        }

        .rooms-wrapper {
            padding: 12px;
        }

        .rooms-header {
            flex-direction: row;
            align-items: center;
            gap: 12px;
        }

        .rooms-title {
            font-size: 22px;
        }

        .top-right-panel {
            grid-template-columns: 100px 1fr;
        }

        .top-right-panel {
            gap: 12px;
        }

        .current-time-box {
            width: 100px;
            height: 56px;
            font-size: 18px;
        }

        .day-btn {
            width: 44px;
            height: 44px;
            font-size: 32px;
        }

        .day-current {
            font-size: 15px;
        }

        .rooms-layout {
            gap: 12px;
        }

        .calendar-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .day-nav {
            width: var(--side-panel-width);
            height: 56px;
            grid-template-columns: 1fr;
        }
    }
</style>

@{
    var usersJson = JsonSerializer.Serialize(
        organizerUsers
            .Select(u => new
            {
                name = u.DisplayName ?? "",
                mail = u.Mail ?? u.UserPrincipalName ?? ""
            })
            .Where(u => !string.IsNullOrWhiteSpace(u.name) && !string.IsNullOrWhiteSpace(u.mail))
            .ToList()
    );
}

<script>
    const users = @Html.Raw(usersJson);

    let firstSelectedSlot = null;
    let selectedSlots = [];

    const slots = Array.from(document.querySelectorAll(".time-slot.free"));
    const allSlotButtons = Array.from(document.querySelectorAll(".time-slot"));
    const selectedRange = document.getElementById("selectedRange");
    const bookingStart = document.getElementById("bookingStart");
    const bookingEnd = document.getElementById("bookingEnd");
    const bookBtn = document.getElementById("bookBtn");
    const organizerEmail = document.getElementById("organizerEmail");
    const clearSelectionBtn = document.getElementById("clearSelectionBtn");
    const currentTime = document.getElementById("currentTime");

    clearSelectionBtn.addEventListener("click", () => {
        clearSelectedSlots();
        updateSelectedRange();

        organizerSearch.value = "";
        organizerEmail.value = "";
        suggestions.style.display = "none";
        suggestions.innerHTML = "";

        document.querySelector('input[name="subject"]').value = "";

        refreshBookButton();
    });

    function updateCurrentTime() {
        const now = new Date();

        currentTime.textContent = now.toLocaleTimeString("pl-PL", {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit"
        });
    }

    updateCurrentTime();
    setInterval(updateCurrentTime, 1000);
    function millisecondsUntilNextMidnight() {
        const now = new Date();
        const nextMidnight = new Date(now);

        nextMidnight.setHours(24, 0, 0, 0);

        return nextMidnight - now;
    }

    setTimeout(() => {
        window.location.reload();
    }, millisecondsUntilNextMidnight());

    slots.forEach(slot => {
        slot.addEventListener("click", () => {
            const clickedTime = slot.dataset.time;

            if (!firstSelectedSlot) {
                clearSelectedSlots();

                firstSelectedSlot = clickedTime;
                selectedSlots = [clickedTime];
                slot.classList.add("selected");

                markUnavailableAfterFirstClick(clickedTime);
                updateSelectedRange();
                return;
            }

            if (firstSelectedSlot === clickedTime) {
                clearSelectedSlots();
                updateSelectedRange();
                return;
            }

            const canSelect = selectRange(firstSelectedSlot, clickedTime);

            if (!canSelect) {
                clearSelectedSlots();
                firstSelectedSlot = clickedTime;
                selectedSlots = [clickedTime];
                slot.classList.add("selected");
                markUnavailableAfterFirstClick(clickedTime);
            } else {
                firstSelectedSlot = null;
                clearRangeBlocked();
            }

            updateSelectedRange();
        });
    });

    function selectRange(startTime, endTime) {
        clearSelectedSlots(false);

        const start = new Date(startTime);
        const end = new Date(endTime);

        const min = start < end ? start : end;
        const max = start < end ? end : start;

        const rangeSlots = allSlotButtons.filter(slot => {
            const slotTime = new Date(slot.dataset.time);
            return slotTime >= min && slotTime <= max;
        });

        const hasBusyInside = rangeSlots.some(slot => slot.classList.contains("busy"));

        if (hasBusyInside) {
            return false;
        }

        selectedSlots = [];

        rangeSlots.forEach(slot => {
            if (slot.classList.contains("free")) {
                selectedSlots.push(slot.dataset.time);
                slot.classList.add("selected");
            }
        });

        selectedSlots.sort();
        return true;
    }

    function markUnavailableAfterFirstClick(startTime) {
        clearRangeBlocked();

        const start = new Date(startTime);
        const sortedAllSlots = [...allSlotButtons].sort((a, b) =>
            new Date(a.dataset.time) - new Date(b.dataset.time));

        const startIndex = sortedAllSlots.findIndex(slot => slot.dataset.time === startTime);

        let firstBusyAfter = null;

        for (let i = startIndex + 1; i < sortedAllSlots.length; i++) {
            if (sortedAllSlots[i].classList.contains("busy")) {
                firstBusyAfter = i;
                break;
            }
        }

        if (firstBusyAfter !== null) {
            for (let i = firstBusyAfter + 1; i < sortedAllSlots.length; i++) {
                sortedAllSlots[i].classList.add("range-blocked");
            }
        }

        let firstBusyBefore = null;

        for (let i = startIndex - 1; i >= 0; i--) {
            if (sortedAllSlots[i].classList.contains("busy")) {
                firstBusyBefore = i;
                break;
            }
        }

        if (firstBusyBefore !== null) {
            for (let i = 0; i < firstBusyBefore; i++) {
                sortedAllSlots[i].classList.add("range-blocked");
            }
        }
    }

    function clearRangeBlocked() {
        allSlotButtons.forEach(slot => {
            slot.classList.remove("range-blocked");
        });
    }

    function clearSelectedSlots(resetFirst = true) {
        selectedSlots = [];

        allSlotButtons.forEach(slot => {
            slot.classList.remove("selected");
            slot.classList.remove("range-blocked");
        });

        if (resetFirst) {
            firstSelectedSlot = null;
        }
    }

    function updateSelectedRange() {
        if (selectedSlots.length === 0) {
            selectedRange.textContent = "Nie wybrano";
            bookingStart.value = "";
            bookingEnd.value = "";
            refreshBookButton();
            return;
        }

        const start = new Date(selectedSlots[0]);
        const end = new Date(selectedSlots[selectedSlots.length - 1]);
        end.setMinutes(end.getMinutes() + 30);

        selectedRange.textContent =
            formatTime(start) + " - " + formatTime(end);

        bookingStart.value = toLocalInputValue(start);
        bookingEnd.value = toLocalInputValue(end);

        refreshBookButton();
    }

    function formatTime(date) {
        return date.toLocaleTimeString("pl-PL", {
            hour: "2-digit",
            minute: "2-digit"
        });
    }

    function toLocalInputValue(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        const hour = String(date.getHours()).padStart(2, "0");
        const minute = String(date.getMinutes()).padStart(2, "0");

        return `${year}-${month}-${day}T${hour}:${minute}:00`;
    }

    const organizerSearch = document.getElementById("organizerSearch");
    const suggestions = document.getElementById("organizerSuggestions");

    organizerSearch.addEventListener("input", () => {
        const value = organizerSearch.value.trim().toLowerCase();

        organizerEmail.value = "";
        refreshBookButton();

        if (value.length < 2) {
            suggestions.style.display = "none";
            suggestions.innerHTML = "";
            return;
        }

        const matched = users
            .filter(u =>
                u.name.toLowerCase().includes(value) ||
                u.mail.toLowerCase().includes(value))
            .slice(0, 8);

        if (matched.length === 0) {
            suggestions.style.display = "none";
            suggestions.innerHTML = "";
            return;
        }

        suggestions.innerHTML = matched.map(u => `
            <div class="suggestion-item" data-name="${u.name}" data-mail="${u.mail}">
                <div class="suggestion-name">${u.name}</div>
                <div class="suggestion-mail">${u.mail}</div>
            </div>
        `).join("");

        suggestions.style.display = "block";

        document.querySelectorAll(".suggestion-item").forEach(item => {
            item.addEventListener("click", () => {
                organizerSearch.value = item.dataset.name;
                organizerEmail.value = item.dataset.mail;
                suggestions.style.display = "none";
                refreshBookButton();
            });
        });
    });

    function refreshBookButton() {
        bookBtn.disabled =
            !bookingStart.value ||
            !bookingEnd.value ||
            !organizerEmail.value;
    }

    let inactivityTimer = null;

    const inactivityLimitMs = 5 * 60 * 1000;

    function resetInactivityTimer() {
        clearTimeout(inactivityTimer);

        inactivityTimer = setTimeout(() => {
            window.location.reload();
        }, inactivityLimitMs);
    }

    ["click", "touchstart", "keydown", "mousemove"].forEach(eventName => {
        document.addEventListener(eventName, resetInactivityTimer, { passive: true });
    });

    resetInactivityTimer();
</script>